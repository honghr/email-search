# Copy to .env and fill in the Azure values. The .env file is git-ignored.

# Source emails as normalized JSONL (produced by the ingest step).
DATA_PATH=../data/emails.jsonl

# Local cross-encoder reranker (CPU fallback, downloaded on first run).
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Cohere rerank on Azure AI Foundry (cloud reranker, no local GPU needed).
# Leave COHERE_RERANK_URL empty to fall back to the local RERANK_MODEL.
COHERE_RERANK_URL=
COHERE_RERANK_DEPLOYMENT=Cohere-rerank-v4.0-fast
USE_RERANK=true

# Retrieval tuning
RECALL_TOP_K=50
FINAL_TOP_K=10

# Your identity, used for "sent by me" queries.
ME_ADDRESS=
ME_NAME=

# --- Azure OpenAI (Azure AI Foundry v1 API) ---------------------------------
# Endpoint ends with /openai/v1 ; no api_version needed.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Deployment names from Azure AI Foundry.
AZURE_EMBED_DEPLOYMENT=text-embedding-3-large
AZURE_EMBED_DIM=3072
AZURE_CHAT_DEPLOYMENT=gpt-4.1-mini

# --- Qdrant vector database -------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=emails

